{
  "name": "gestor-de-axyam",
  "version": "1.1.7",
  "description": "Gestor de personajes, equipamiento y materiales para servidor de rol Axyam",
  "main": "dist-electron/main.js",
  "author": "Valant-Oni",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "postinstall": "electron-rebuild",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --config.win.target=portable",
    "release": "npm version patch --no-git-tag-version && npm run dist:portable",
    "release:minor": "npm version minor --no-git-tag-version && npm run dist:portable"
  },
  "build": {
    "appId": "com.axyam.gestor",
    "productName": "Gestor de Axyam",
    "directories": {
      "output": "release/installer"
    },
    "extraResources": [
      {
        "from": "resources/csv",
        "to": "csv"
      },
      {
        "from": "resources/item_tags_seed.json",
        "to": "item_tags_seed.json"
      },
      {
        "from": "resources/item_attributes_seed.json",
        "to": "item_attributes_seed.json"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "certificateFile": "resources/cert.pfx",
        "certificatePassword": "axyam2026"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "better-sqlite3": "^12.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^1.0.0",
    "papaparse": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/papaparse": "^5.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^1.0.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
